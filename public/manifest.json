{
  "manifest_version": 3,
  "name": "AO3 Tag Highlighter",
  "version": "0.1.0",
  "description": "Highlight, warn, mute, or collapse AO3 works based on tag rules.",
  "permissions": ["storage"],
  "host_permissions": ["https://archiveofourown.org/*"],
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://archiveofourown.org/*"],
      "css": ["assets/content.css"],
      "js": ["content/index.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "options_page": "options.html"
}
